{
  "name": "@repo/virtual-authenticator-agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./validation": "./src/validation/index.ts",
    "./dto": "./src/dto/index.ts"
  },
  "scripts": {
    "build": "run-p barrel:*",
    "barrel:authenticatorAgent": "../../scripts/barrel.ts ./src",
    "barrel:validation": "../../scripts/barrel.ts ./src/validation",
    "barrel:dto": "../../scripts/barrel.ts ./src/dto",
    "test:unit": "vitest run --config __tests__/vitest.unit.config.ts",
    "test:unit:coverage": "vitest run --coverage --config __tests__/vitest.unit.config.ts",
    "test:integration": "vitest run --config __tests__/vitest.integration.config.ts",
    "test:integration:coverage": "vitest run --coverage --config __tests__/vitest.integration.config.ts",
    "lint": "eslint .",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@repo/auth": "workspace:*",
    "@repo/core": "workspace:*",
    "@repo/eslint-config": "workspace:*",
    "@repo/prisma": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@repo/vitest-config": "workspace:*",
    "@simplewebauthn/server": "^13.2.1",
    "@simplewebauthn/types": "^12.0.0",
    "@types/node": "^22.5.2",
    "ts-morph": "^27.0.2",
    "type-fest": "^5.0.1",
    "typescript": "^5.5.4",
    "vitest": "^3.2.4",
    "vitest-mock-extended": "^3.1.0"
  },
  "dependencies": {
    "@repo/assert": "workspace:*",
    "@repo/cbor": "workspace:*",
    "@repo/core": "workspace:*",
    "@repo/crypto": "workspace:*",
    "@repo/exception": "workspace:*",
    "@repo/http": "workspace:*",
    "@repo/keys": "workspace:*",
    "@repo/types": "workspace:*",
    "@repo/utils": "workspace:*",
    "@repo/virtual-authenticator": "workspace:*",
    "buffer": "^6.0.3",
    "cbor2": "^2.0.1",
    "effect": "^3.19.4",
    "zod": "^4.1.12"
  }
}
